# ============================================
# TERRAFORM - FILES AND FOLDERS TO IGNORE
# ============================================
# Terraform State Files (DO NOT COMMIT)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl.lock
.terraformrc
terraform.rc

# Terraform Plan Files (temporary, usually do not commit)
*.tfplan
*.out

# Terraform Directories
.terraform.d/

# AWS Credentials and Secrets
aws_credentials
.aws/
credentials
secret_key

# Override Files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash Log Files
crash.log

# Terraform credentials
creds.tfvars
crash.*.log

# Ignore CLI configuration files
cli.json

# ============================================
# TERRAFORM - FILES TO TRACK (NOT IGNORE)
# ============================================
# .tf files should be committed
!*.tf
!*.tfvars
!terraform.tfvars
# Module files should be committed
!module/
!modules/
# Backend configuration should be committed
!backend.tf
# Variable definitions should be committed
!variables.tf
!outputs.tf

